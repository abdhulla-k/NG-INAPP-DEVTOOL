{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true,
        "baseUrl": "./",
        "paths": {
            "rxjs": [
                "../node_modules/rxjs"
            ],
            "rxjs/*": [
                "../node_modules/rxjs/*"
            ]
        }
    },
    "include": [
        "index.ts",
        "schema.json"
    ]
}